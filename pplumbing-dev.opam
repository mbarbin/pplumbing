# This file is generated by dune, edit dune-project instead
opam-version: "2.0"
synopsis: "Package to regroup dev targets, documentation, and more"
maintainer: ["Mathieu Barbin <opensource@mbarbin.org>"]
authors: ["Mathieu Barbin"]
license: "MIT"
homepage: "https://github.com/mbarbin/pplumbing"
doc: "https://mbarbin.github.io/pplumbing/"
bug-reports: "https://github.com/mbarbin/pplumbing/issues"
depends: [
  "dune" {>= "3.17"}
  "ocaml" {>= "5.2"}
  "ocamlformat" {= "0.29.0"}
  "bisect_ppx" {>= "2.8.3"}
  "cmdlang-climate-err-runner" {= version}
  "cmdlang-cmdliner-err-runner" {= version}
  "pplumbing-err" {= version}
  "pplumbing-log" {= version}
  "pplumbing-log-cli" {= version}
  "pplumbing-pp-tty" {= version}
  "pplumbing-tests" {= version}
  "ppx_js_style" {>= "v0.17"}
  "sherlodoc" {>= "0.2"}
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
dev-repo: "git+https://github.com/mbarbin/pplumbing.git"
